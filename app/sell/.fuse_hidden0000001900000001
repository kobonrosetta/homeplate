"use server";

import { redirect } from "next/navigation";
import { revalidatePath } from "next/cache";
import { createClient } from "@/lib/supabase/server";
import { slugify } from "@/lib/slug";

export async function createKitchen(formData: FormData) {
  const supabase = createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user) redirect("/login");

  const businessName = String(formData.get("business_name") ?? "").trim();
  const operationType = String(formData.get("operation_type") ?? "cottage");
  const permitNumber = String(formData.get("permit_number") ?? "").trim();
  const bio = String(formData.get("bio") ?? "").trim();
  const city = String(formData.get("city") ?? "").trim();
  const zip = String(formData.get("zip") ?? "").trim();
  const cuisineTags = String(formData.get("cuisine_tags") ?? "")
    .split(",")
    .map((s) => s.trim())
    .filter(Boolean);
  const pickup = formData.get("pickup_available") === "on";
  const delivery = formData.get("delivery_available") === "on";
  const deliveryNotes = String(formData.get("delivery_notes") ?? "").trim();

  if (!businessName || !permitNumber) {
    redirect(
      "/sell?error=" +
        encodeURIComponent("Business name and permit number are required.")
    );
  }

  // Already have a kitchen? Go manage it. (limit(1) is robust even if
  // duplicates somehow exist; the DB constraint below prevents new ones.)
  const { data: existing } = await supabase
    .from("cooks")
    .select("id")
    .eq("profile_id", user.id)
    .limit(1);
  if (existing && existing.length > 0) redirect("/dashboard");

  // Verify the permit against the county approved-operator list.
  const { data: match } = await supabase
    .from("approved_operators")
    .select("id")
    .ilike("permit_number", permitNumber)
    .maybeSingle();
  const verified = Boolean(match);

  // Insert the kitchen, retrying with a random slug suffix if the URL slug is
  // already taken. No pre-check query, so a flaky connection can't cause a
  // false "slug is free" and crash on a duplicate.
  const baseSlug = slugify(businessName);
  const cookData = {
    profile_id: user.id,
    business_name: businessName,
    bio: bio || null,
    operation_type: operationType,
    permit_number: permitNumber,
    permit_verified: verified,
    approved_operator_id: match?.id ?? null,
    city: city || null,
    zip: zip || null,
    cuisine_tags: cuisineTags,
    pickup_available: pickup,
    delivery_available: delivery,
    delivery_notes: deliveryNotes || null,
    status: verified ? "active" : "pending",
  };

  let lastError: { code?: string; message: string } | null = null;
  for (let attempt = 0; attempt < 4; attempt++) {
    const slug =
      attempt === 0
        ? baseSlug
        : `${baseSlug}-${Math.random().toString(36).slice(2, 6)}`;
    const { error } = await supabase.from("cooks").insert({ ...cookData, slug });
    if (!error) {
      lastError = null;
      break;
    }
    lastError = error;
    // Only retry when the slug specifically collided (23505 = unique_violation).
    if (!(error.code === "23505" && /slug/i.test(error.message))) break;
  }
  if (lastError) {
    redirect("/sell?error=" + encodeURIComponent(lastError.message));
  }

  await supabase.from("profiles").update({ is_cook: true }).eq("id", user.id);
  revalidatePath("/", "layout");
  redirect("/dashboard");
}
