import { redirect } from "next/navigation";
import { getCurrentCook } from "@/lib/cook";
import { createKitchen } from "./actions";
import {
  TextField,
  TextArea,
  SelectField,
  CheckboxField,
  SubmitButton,
  FormError,
} from "@/components/form";

export default async function SellPage({
  searchParams,
}: {
  searchParams: { error?: string };
}) {
  const { user, cook } = await getCurrentCook();
  if (!user) redirect("/login");
  if (cook) redirect("/dashboard");

  return (
    <main className="mx-auto max-w-2xl px-6 py-12">
      <h1 className="text-3xl font-semibold text-stone-900">List your kitchen</h1>
      <p className="mt-2 text-stone-600">
        Tell buyers who you are. We&apos;ll verify your permit against the county
        approved list so customers know you&apos;re the real deal.
      </p>

      <form action={createKitchen} className="mt-8 space-y-5">
        <FormError message={searchParams.error} />

        <TextField
          label="Kitchen / business name"
          name="business_name"
          required
          placeholder="Kate's Bread"
        />

        <SelectField
          label="Operation type"
          name="operation_type"
          defaultValue="cottage"
          options={[
            { value: "cottage", label: "Cottage food (baked goods, jams, shelf-stable)" },
            { value: "mehko", label: "MEHKO (hot home-cooked meals)" },
          ]}
        />

        <TextField
          label="Permit number"
          name="permit_number"
          required
          placeholder="e.g. MEHKO-2025-001"
        />

        <TextArea
          label="Short bio"
          name="bio"
          rows={3}
          placeholder="Third-generation baker. Sourdough fermented 36 hours, baked fresh every weekend."
        />

        <div className="grid grid-cols-2 gap-4">
          <TextField label="City" name="city" placeholder="Sunnyvale" />
          <TextField label="ZIP" name="zip" placeholder="94086" />
        </div>

        <TextField
          label="Cuisine tags (comma separated)"
          name="cuisine_tags"
          placeholder="sourdough, pastries, vegan"
        />

        <div className="space-y-3 rounded-lg border border-stone-200 p-4">
          <p className="text-sm font-medium text-stone-700">How do customers get their food?</p>
          <CheckboxField label="Pickup available" name="pickup_available" defaultChecked />
          <CheckboxField label="Delivery available" name="delivery_available" />
          <TextField
            label="Delivery notes (optional)"
            name="delivery_notes"
            placeholder="Within 5 miles, $5 fee"
          />
        </div>

        <SubmitButton>Create my kitchen</SubmitButton>
      </form>
    </main>
  );
}
