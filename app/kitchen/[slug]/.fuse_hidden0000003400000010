import { notFound } from "next/navigation";
import { createClient } from "@/lib/supabase/server";
import { formatUsd } from "@/lib/constants";
import AddToCart from "@/components/add-to-cart";

export const dynamic = "force-dynamic";

export default async function KitchenPage({
  params,
}: {
  params: { slug: string };
}) {
  const supabase = createClient();
  const { data: cook } = await supabase
    .from("cooks")
    .select("*")
    .eq("slug", params.slug)
    .eq("status", "active")
    .maybeSingle();

  if (!cook) notFound();

  const { data: listings } = await supabase
    .from("listings")
    .select("*")
    .eq("cook_id", cook.id)
    .eq("is_available", true)
    .order("created_at", { ascending: false });

  const items = listings ?? [];

  return (
    <main className="mx-auto max-w-4xl px-6 py-10">
      <div className="flex flex-wrap items-start justify-between gap-3">
        <div>
          <h1 className="text-3xl font-semibold text-stone-900">
            {cook.business_name}
          </h1>
          <p className="mt-1 text-stone-600">
            {cook.city ? `${cook.city} · ` : ""}
            {cook.operation_type === "mehko" ? "Home kitchen" : "Cottage food"}
          </p>
        </div>
        {cook.permit_verified && (
          <span className="rounded-full bg-emerald-100 px-3 py-1.5 text-sm font-medium text-emerald-800">
            ✓ County-verified
          </span>
        )}
      </div>

      {cook.bio && (
        <p className="mt-4 max-w-2xl leading-relaxed text-stone-700">{cook.bio}</p>
      )}

      <div className="mt-3 flex flex-wrap gap-2 text-sm text-stone-500">
        {cook.pickup_available && (
          <span className="rounded-full bg-stone-100 px-3 py-1">Pickup</span>
        )}
        {cook.delivery_available && (
          <span className="rounded-full bg-stone-100 px-3 py-1">Delivery</span>
        )}
        {(cook.cuisine_tags ?? []).map((t: string) => (
          <span key={t} className="rounded-full bg-stone-100 px-3 py-1">
            {t}
          </span>
        ))}
      </div>

      <h2 className="mt-10 text-lg font-semibold text-stone-900">Menu</h2>
      {items.length === 0 ? (
        <p className="mt-4 text-stone-500">No items available right now.</p>
      ) : (
        <div className="mt-4 grid gap-5 sm:grid-cols-2">
          {items.map((l: any) => (
            <div key={l.id} className="flex gap-4 rounded-xl border border-stone-200 p-4">
              {l.photo_url ? (
                // eslint-disable-next-line @next/next/no-img-element
                <img
                  src={l.photo_url}
                  alt={l.title}
                  className="h-24 w-24 shrink-0 rounded-lg object-cover"
                />
              ) : (
                <div className="flex h-24 w-24 shrink-0 items-center justify-center rounded-lg bg-stone-100 text-3xl text-stone-300">
                  🍽️
                </div>
              )}
              <div className="flex min-w-0 flex-1 flex-col">
                <p className="font-medium text-stone-900">{l.title}</p>
                {l.description && (
                  <p className="mt-1 line-clamp-2 text-sm text-stone-500">
                    {l.description}
                  </p>
                )}
                {l.lead_time_note && (
                  <p className="mt-1 text-xs text-stone-400">{l.lead_time_note}</p>
                )}
                <div className="mt-auto flex items-center justify-between pt-2">
                  <span className="font-semibold text-stone-900">
                    {formatUsd(l.price_cents)}
                  </span>
                  <AddToCart
                    cook={{ id: cook.id, name: cook.business_name, slug: cook.slug }}
                    item={{
                      listingId: l.id,
                      title: l.title,
                      priceCents: l.price_cents,
                      photoUrl: l.photo_url,
                    }}
                  />
                </div>
              </div>
            </div>
          ))}
        </div>
      )}
    </main>
  );
}
