"use server";

import { redirect } from "next/navigation";
import { revalidatePath } from "next/cache";
import { createClient } from "@/lib/supabase/server";
import { checkPhotoImage } from "@/lib/ai";
import { MIN_PHOTO_SCORE } from "@/lib/constants";

// Make sure the caller is a logged-in cook, and return their kitchen.
async function requireCook() {
  const supabase = createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();
  if (!user) redirect("/login");

  const { data: cooks } = await supabase
    .from("cooks")
    .select("id")
    .eq("profile_id", user.id)
    .order("created_at", { ascending: false })
    .limit(1);
  const cook = cooks?.[0];
  if (!cook) redirect("/sell");

  return { supabase, cook };
}

export async function createListing(formData: FormData) {
  const { supabase, cook } = await requireCook();

  const title = String(formData.get("title") ?? "").trim();
  const category = String(formData.get("category") ?? "other");
  const priceDollars = parseFloat(String(formData.get("price") ?? ""));
  const description = String(formData.get("description") ?? "").trim();
  const quantity = parseInt(String(formData.get("quantity_available") ?? "0"), 10);
  const leadTime = String(formData.get("lead_time_note") ?? "").trim();

  if (!title || Number.isNaN(priceDollars)) {
    redirect(
      "/dashboard/listings/new?error=" +
        encodeURIComponent("A title and a valid price are required.")
    );
  }

  // Optional photo: upload to Supabase Storage, then AI-check its quality.
  let photoUrl: string | null = null;
  let qualityScore: number | null = null;
  const photo = formData.get("photo");
  if (photo instanceof File && photo.size > 0) {
    const ext = (photo.name.split(".").pop() || "jpg").toLowerCase();
    const path = `${cook.id}/${crypto.randomUUID()}.${ext}`;
    const { error: uploadError } = await supabase.storage
      .from("listing-photos")
      .upload(path, photo, {
        contentType: photo.type || "image/jpeg",
        upsert: false,
      });
    if (!uploadError) {
      const { data: pub } = supabase.storage
        .from("listing-photos")
        .getPublicUrl(path);
      photoUrl = pub.publicUrl;

      // Authoritative server-side gate: a bad photo is rejected and removed,
      // so a client that bypasses the browser check still can't publish it.
      const check = await checkPhotoImage(photoUrl);
      qualityScore = check?.score ?? null;
      if (qualityScore !== null && qualityScore < MIN_PHOTO_SCORE) {
        await supabase.storage.from("listing-photos").remove([path]);
        redirect(
          "/dashboard/listings/new?error=" +
            encodeURIComponent(
              `Photo scored ${qualityScore}/100${
                check?.feedback ? ` — ${check.feedback}` : ""
              }. Please upload a clear photo of the actual food.`
            )
        );
      }
    }
  }

  const { error } = await supabase.from("listings").insert({
    cook_id: cook.id,
    title,
    category,
    price_cents: Math.round(priceDollars * 100),
    description: description || null,
    quantity_available: Number.isNaN(quantity) ? 0 : quantity,
    lead_time_note: leadTime || null,
    photo_url: photoUrl,
    photo_quality_score: qualityScore,
    is_available: true,
  });
  if (error) {
    redirect("/dashboard/listings/new?error=" + encodeURIComponent(error.message));
  }

  revalidatePath("/dashboard");
  redirect("/dashboard");
}

export async function toggleListing(formData: FormData) {
  const { supabase, cook } = await requireCook();
  const id = String(formData.get("id"));
  const next = String(formData.get("next")) === "true";
  await supabase
    .from("listings")
    .update({ is_available: next })
    .eq("id", id)
    .eq("cook_id", cook.id);
  revalidatePath("/dashboard");
}

export async function deleteListing(formData: FormData) {
  const { supabase, cook } = await requireCook();
  const id = String(formData.get("id"));
  await supabase.from("listings").delete().eq("id", id).eq("cook_id", cook.id);
  revalidatePath("/dashboard");
}
