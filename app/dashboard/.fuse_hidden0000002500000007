import Link from "next/link";
import { redirect } from "next/navigation";
import { createClient } from "@/lib/supabase/server";
import { getCurrentCook } from "@/lib/cook";
import { formatUsd } from "@/lib/constants";
import { toggleListing, deleteListing } from "./listings/actions";

export default async function DashboardPage() {
  const { user, cook } = await getCurrentCook();
  if (!user) redirect("/login");
  if (!cook) redirect("/sell");

  const supabase = createClient();
  const { data: listings } = await supabase
    .from("listings")
    .select("*")
    .eq("cook_id", cook.id)
    .order("created_at", { ascending: false });

  const items = listings ?? [];

  return (
    <main className="mx-auto max-w-4xl px-6 py-10">
      {/* Kitchen header */}
      <div className="flex flex-wrap items-start justify-between gap-4">
        <div>
          <h1 className="text-2xl font-semibold text-stone-900">
            {cook.business_name}
          </h1>
          <p className="mt-1 text-stone-600">
            {cook.operation_type === "mehko" ? "Home kitchen (MEHKO)" : "Cottage food"}
            {cook.city ? ` · ${cook.city}` : ""}
          </p>
        </div>
        {cook.permit_verified ? (
          <span className="inline-flex items-center gap-1.5 rounded-full bg-emerald-100 px-3 py-1.5 text-sm font-medium text-emerald-800">
            ✓ Verified
          </span>
        ) : (
          <span className="inline-flex items-center gap-1.5 rounded-full bg-amber-100 px-3 py-1.5 text-sm font-medium text-amber-800">
            ⏳ Pending verification
          </span>
        )}
      </div>

      {!cook.permit_verified && (
        <p className="mt-4 rounded-lg bg-amber-50 px-4 py-3 text-sm text-amber-800">
          We couldn&apos;t match your permit to the county approved list yet, so
          your kitchen isn&apos;t public. Double-check your permit number, or it
          may just need to be added to our records.
        </p>
      )}

      {/* Listings */}
      <div className="mt-10 flex items-center justify-between">
        <h2 className="text-lg font-semibold text-stone-900">Your menu</h2>
        <Link
          href="/dashboard/listings/new"
          className="rounded-full bg-stone-900 px-4 py-2 text-sm font-medium text-white hover:bg-stone-700"
        >
          + Add a listing
        </Link>
      </div>

      {items.length === 0 ? (
        <p className="mt-6 rounded-lg border border-dashed border-stone-300 px-4 py-10 text-center text-stone-500">
          No listings yet. Add your first item to start selling.
        </p>
      ) : (
        <ul className="mt-6 divide-y divide-stone-200 rounded-lg border border-stone-200">
          {items.map((l: any) => (
            <li key={l.id} className="flex items-center justify-between gap-4 px-4 py-4">
              <div className="flex min-w-0 items-center gap-3">
                {l.photo_url ? (
                  // eslint-disable-next-line @next/next/no-img-element
                  <img
                    src={l.photo_url}
                    alt=""
                    className="h-12 w-12 shrink-0 rounded-lg object-cover"
                  />
                ) : (
                  <div className="flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-stone-100 text-stone-400">
                    🍽️
                  </div>
                )}
                <div className="min-w-0">
                  <p className="font-medium text-stone-900">{l.title}</p>
                  <p className="text-sm text-stone-500">
                    {formatUsd(l.price_cents)} · {l.quantity_available} available
                    {l.is_available ? "" : " · hidden"}
                    {typeof l.photo_quality_score === "number"
                      ? ` · photo ${l.photo_quality_score}/100`
                      : ""}
                  </p>
                </div>
              </div>
              <div className="flex shrink-0 items-center gap-2">
                <form action={toggleListing}>
                  <input type="hidden" name="id" value={l.id} />
                  <input type="hidden" name="next" value={String(!l.is_available)} />
                  <button
                    type="submit"
                    className="rounded-full border border-stone-300 px-3 py-1.5 text-sm text-stone-700 hover:bg-stone-50"
                  >
                    {l.is_available ? "Hide" : "Show"}
                  </button>
                </form>
                <form action={deleteListing}>
                  <input type="hidden" name="id" value={l.id} />
                  <button
                    type="submit"
                    className="rounded-full border border-stone-300 px-3 py-1.5 text-sm text-red-600 hover:bg-red-50"
                  >
                    Delete
                  </button>
                </form>
              </div>
            </li>
          ))}
        </ul>
      )}
    </main>
  );
}
