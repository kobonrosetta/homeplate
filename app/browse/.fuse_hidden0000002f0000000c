import Link from "next/link";
import { createClient } from "@/lib/supabase/server";
import { formatUsd } from "@/lib/constants";

export const dynamic = "force-dynamic";

export default async function BrowsePage() {
  const supabase = createClient();
  const { data: listings } = await supabase
    .from("listings")
    .select(
      "id, title, price_cents, photo_url, category, cooks!inner(business_name, slug, city, permit_verified, status)"
    )
    .eq("is_available", true)
    .eq("cooks.status", "active")
    .gt("quantity_available", 0)
    .order("created_at", { ascending: false })
    .limit(60);

  const items = listings ?? [];

  return (
    <main className="mx-auto max-w-6xl px-6 py-10">
      <h1 className="text-2xl font-semibold text-stone-900">Browse local kitchens</h1>
      <p className="mt-1 text-stone-600">
        Verified home cooks and bakers near you.
      </p>

      {items.length === 0 ? (
        <p className="mt-10 rounded-lg border border-dashed border-stone-300 px-4 py-16 text-center text-stone-500">
          No food listed yet. Check back soon.
        </p>
      ) : (
        <div className="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {items.map((l: any) => {
            const cook = Array.isArray(l.cooks) ? l.cooks[0] : l.cooks;
            return (
              <Link
                key={l.id}
                href={`/kitchen/${cook.slug}`}
                className="group overflow-hidden rounded-xl border border-stone-200 transition hover:shadow-md"
              >
                <div className="aspect-[4/3] bg-stone-100">
                  {l.photo_url ? (
                    // eslint-disable-next-line @next/next/no-img-element
                    <img
                      src={l.photo_url}
                      alt={l.title}
                      className="h-full w-full object-cover"
                    />
                  ) : (
                    <div className="flex h-full items-center justify-center text-4xl text-stone-300">
                      🍽️
                    </div>
                  )}
                </div>
                <div className="p-4">
                  <div className="flex items-center justify-between gap-2">
                    <p className="font-medium text-stone-900">{l.title}</p>
                    <p className="font-semibold text-stone-900">
                      {formatUsd(l.price_cents)}
                    </p>
                  </div>
                  <p className="mt-1 text-sm text-stone-500">
                    {cook.business_name}
                    {cook.permit_verified ? " · ✓ Verified" : ""}
                    {cook.city ? ` · ${cook.city}` : ""}
                  </p>
                </div>
              </Link>
            );
          })}
        </div>
      )}
    </main>
  );
}
