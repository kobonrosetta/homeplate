import Link from "next/link";
import { createClient } from "@/lib/supabase/server";
import { signout } from "@/app/(auth)/actions";
import CartButton from "@/components/cart-button";

// Global header. Reads the logged-in user on the server and shows
// the right actions for signed-in vs signed-out visitors.
export default async function SiteHeader() {
  const supabase = createClient();
  const {
    data: { user },
  } = await supabase.auth.getUser();

  return (
    <header className="border-b border-stone-200">
      <div className="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <Link href="/" className="flex items-center gap-2">
          <span className="text-2xl">🍽️</span>
          <span className="text-xl font-semibold tracking-tight text-stone-800">
            HomePlate
          </span>
        </Link>

        <nav className="flex items-center gap-5 text-sm">
          <Link href="/browse" className="text-stone-600 hover:text-stone-900">
            Browse kitchens
          </Link>

          <CartButton />

          {user ? (
            <>
              <Link
                href="/sell"
                className="text-stone-600 hover:text-stone-900"
              >
                List your kitchen
              </Link>
              <span className="hidden text-stone-400 sm:inline">
                {user.email}
              </span>
              <form action={signout}>
                <button
                  type="submit"
                  className="rounded-full border border-stone-300 px-4 py-2 font-medium text-stone-800 hover:bg-stone-50"
                >
                  Sign out
                </button>
              </form>
            </>
          ) : (
            <>
              <Link href="/login" className="text-stone-600 hover:text-stone-900">
                Sign in
              </Link>
              <Link
                href="/signup"
                className="rounded-full bg-stone-900 px-4 py-2 font-medium text-white hover:bg-stone-700"
              >
                Get started
              </Link>
            </>
          )}
        </nav>
      </div>
    </header>
  );
}
