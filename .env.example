# Copy this file to ".env.local" and fill in your own keys.
# .env.local is gitignored, so your secrets never get committed.

# --- Supabase (Project Settings -> API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Developers -> API keys) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Groq (for AI descriptions + photo checks; free tier is fine) ---
GROQ_API_KEY=

# --- Resend (transactional email; verify a domain to send to real users) ---
RESEND_API_KEY=
EMAIL_FROM=HomePlate <onboarding@resend.dev>

# --- Admin console access (comma-separated emails allowed at /admin) ---
ADMIN_EMAILS=

# --- App (in production set this to your live URL, e.g. https://homeplate.onrender.com) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
